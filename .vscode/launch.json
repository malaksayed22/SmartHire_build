{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "🚀 Run SmartHire Server",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/serve.js",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
